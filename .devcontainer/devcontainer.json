{
  "name": "specdojo",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },
  "remoteUser": "node",
  "workspaceMount": "source=${localWorkspaceFolder}/..,target=/workspaces/specdojo-workspace,type=bind,consistency=cached",
  "workspaceFolder": "/workspaces/specdojo-workspace/specdojo",
  "shutdownAction": "none",

  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": false,
      "upgradePackages": false
    },
    "ghcr.io/devcontainers-extra/features/yamllint:2": {},
    "ghcr.io/devcontainers/features/copilot-cli:1": {},
    "ghcr.io/devcontainers/features/python:1": {},
    "ghcr.io/va-h/devcontainers-features/uv:1": {},
    "ghcr.io/anthropics/devcontainer-features/claude-code:1.0": {},
    "ghcr.io/rocker-org/devcontainer-features/apt-packages:1": {
      "packages": "ripgrep,fd-find,gh,fzf,yq,shellcheck,shfmt,tmux",
      "upgradePackages": false
    }
  },

  "mounts": [
    "source=specdojo-git,target=/home/node/.config/git,type=volume",
    "source=specdojo-claude,target=/home/node/.claude,type=volume",
    "source=specdojo-claude-state,target=/home/node/.claude-state,type=volume",
    "source=specdojo-codex,target=/home/node/.codex,type=volume",
    "source=specdojo-copilot,target=/home/node/.copilot,type=volume",
    "source=specdojo-opencode,target=/home/node/.config/opencode,type=volume",
    "source=specdojo-gh,target=/home/node/.config/gh,type=volume"
  ],

  "containerEnv": {
    "GIT_CONFIG_GLOBAL": "/home/node/.config/git/config",
    "COPILOT_HOME": "/home/node/.copilot",
    "OLLAMA_BASE_URL": "http://host.docker.internal:11434",
    "LOCAL_OPENAI_BASE_URL": "http://host.docker.internal:11434/v1",
    "COMFYUI_BASE_URL": "http://host.docker.internal:8188",
    "OPENCODE_DISABLE_AUTO_UPDATE": "1"
  },

  "runArgs": [
    "--add-host=host.docker.internal:host-gateway",
    "--security-opt=apparmor=unconfined",
    "--security-opt=seccomp=unconfined"
  ],

  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "postStartCommand": "bash .devcontainer/post-start.sh",

  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "streetsidesoftware.code-spell-checker",
        "mhutchie.git-graph",
        "openai.chatgpt",
        "github.copilot",
        "github.copilot-chat",
        "CucumberOpen.cucumber-official",
        "redhat.vscode-yaml",
        "davidanson.vscode-markdownlint",
        "usernamehw.errorlens",
        "editorconfig.editorconfig",
        "esbenp.prettier-vscode",
        "unifiedjs.vscode-remark",
        "yzhang.markdown-all-in-one",
        "vue.volar",
        "redhat.vscode-xml"
      ]
    }
  }
}
