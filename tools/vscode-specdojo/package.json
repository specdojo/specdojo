{
  "name": "vscode-specdojo",
  "displayName": "SpecDojo",
  "description": "Document ID navigation for SpecDojo projects",
  "version": "0.1.0",
  "publisher": "specdojo",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:markdown",
    "onLanguage:yaml"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "markdown.markdownItPlugins": true,
    "commands": [
      {
        "command": "specdojo.openById",
        "title": "SpecDojo: Open Document by ID"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npm run compile && vsce package --allow-missing-repository",
    "reinstall": "code --uninstall-extension specdojo.vscode-specdojo; code --install-extension vscode-specdojo-0.1.0.vsix",
    "rebuild": "npm run package && code --uninstall-extension specdojo.vscode-specdojo; code --install-extension vscode-specdojo-0.1.0.vsix"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^5.0.0"
  }
}
