<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
    <dict>
        <key>Label</key>
        <string>org.specdojo.ollama-env</string>

        <key>ProgramArguments</key>
        <array>
            <string>/bin/sh</string>
            <string>-c</string>
            <string>launchctl setenv OLLAMA_KEEP_ALIVE 10m; launchctl setenv OLLAMA_MAX_LOADED_MODELS 2; /usr/bin/killall Ollama 2>/dev/null || true; sleep 2; /usr/bin/open -a Ollama --args hidden</string>
        </array>

        <key>RunAtLoad</key>
        <true />

        <key>StandardOutPath</key>
        <string>/tmp/ollama-env.out.log</string>

        <key>StandardErrorPath</key>
        <string>/tmp/ollama-env.err.log</string>
    </dict>
</plist>
