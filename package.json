{
  "name": "specdojo",
  "version": "0.1.0",
  "description": "SpecDojo CLI, schemas, and documentation for specification-driven execution workflows.",
  "license": "MIT",
  "author": "naoji3x",
  "private": false,
  "type": "module",
  "bin": {
    "specdojo": "dist/specdojo.js"
  },
  "files": [
    "dist",
    "docs/ja/specdojo",
    "docs/specdojo",
    "tools/docs/src",
    "tools/docs/tsconfig.json",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/specdojo/specdojo.git"
  },
  "homepage": "https://github.com/specdojo/specdojo#readme",
  "bugs": {
    "url": "https://github.com/specdojo/specdojo/issues"
  },
  "keywords": [
    "specdojo",
    "cli",
    "specification",
    "project-management",
    "workflow"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepare": "lefthook install",
    "pre-commit": "lefthook run pre-commit",
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.build.json && node -e \"require('node:fs').chmodSync('dist/specdojo.js', 0o755)\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx src/specdojo.ts",
    "start": "node dist/specdojo.js",
    "prepack": "npm run build",
    "specdojo:build": "npm run build",
    "lint:ts": "eslint 'src/**/*.ts' 'tests/**/*.ts' 'tools/docs/src/**/*.ts'",
    "lint:ts:fix": "eslint --fix 'src/**/*.ts' 'tests/**/*.ts' 'tools/docs/src/**/*.ts'",
    "lint:md": "markdownlint '**/*.md'",
    "lint:md:fix": "markdownlint --fix '**/*.md'",
    "docs:dev": "vitepress dev . --host 0.0.0.0 --port 5173",
    "docs:build:mermaid": "tsx tools/docs/src/gen-mermaid-svg.ts",
    "docs:rebuild:mermaid": "rm -f public/mermaid/*.svg && npm run docs:build:mermaid",
    "docs:build": "vitepress build .",
    "lint:fm": "remark \"docs/**/*.{md,mdx}\" --quiet --frail",
    "validate:schema:bdd": "ajv --spec=draft2020 --strict=true -s docs/specdojo/schemas/v1/bdd.schema.yaml -d \"docs/**/bdd-*.yaml\"",
    "validate:schema:esil": "ajv --spec=draft2020 --strict=true -s docs/specdojo/schemas/v1/esil.schema.yaml -d \"docs/**/esil-*.yaml\"",
    "validate:schema:sch-milestones": "tsx tools/docs/src/validate-yaml-schema.ts --schema docs/specdojo/schemas/v1/sch-milestones.schema.yaml --data \"docs/ja/**/sch-milestones*.yaml\"",
    "validate:schema:sch-track": "tsx tools/docs/src/validate-yaml-schema.ts --schema docs/specdojo/schemas/v1/sch-track.schema.yaml --data \"docs/ja/**/sch-track-*.yaml\" --allow-empty",
    "validate:schema:sch-strategy": "tsx tools/docs/src/validate-yaml-schema.ts --schema docs/specdojo/schemas/v1/sch-strategy.schema.yaml --data \"docs/ja/**/sch-strategy-*.yaml\" --allow-empty",
    "validate:schema:exec-defaults": "tsx tools/docs/src/validate-yaml-schema.ts --schema docs/specdojo/schemas/v1/exec-defaults.schema.yaml --data \".specdojo/exec-defaults.yaml\" --allow-empty",
    "validate:schema:file": "tsx tools/docs/src/validate-yaml-schema.ts",
    "validate:schema:pjr-index": "tsx tools/docs/src/validate-md-content.ts --schema docs/specdojo/schemas/v1/pjr-index.schema.yaml --data \"docs/ja/**/pjr-index.md\"",
    "validate:schema": "npm run validate:schema:bdd && npm run validate:schema:esil && npm run validate:schema:sch-milestones && npm run validate:schema:sch-track && npm run validate:schema:sch-strategy && npm run validate:schema:exec-defaults && npm run validate:schema:pjr-index",
    "validate:catalog": "tsx src/specdojo.ts catalog validate",
    "check": "npm run lint:ts && npm run lint:md && npm run lint:fm && npm run validate:schema && npm run validate:catalog && npm test",
    "dc:ps": "docker ps --format \"table {{.Names}}\\t{{.Image}}\\t{{.Status}}\"",
    "dc:name": "bash -lc 'docker ps --format \"{{.Names}}\\t{{.Image}}\" | awk \"\\$2 ~ /^vsc-specdojo/ {print \\$1; exit}\"'",
    "dc:bash": "bash -lc 'name=$(docker ps --format \"{{.Names}}\\t{{.Image}}\" | awk \"\\$2 ~ /^vsc-specdojo/ {print \\$1; exit}\"); [ -n \"$name\" ] && docker exec -it --detach-keys=\"ctrl-]\" -e LANG=C.UTF-8 -e LC_ALL=C.UTF-8 -u node \"$name\" bash -lc \"cd /workspaces/specdojo-workspace/specdojo && exec bash\" || echo \"matching container not found\"'"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "dotenv": "^17.4.2",
    "js-yaml": "^4.2.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@mermaid-js/mermaid-cli": "^11.15.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.2",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "ajv": "^8.20.0",
    "ajv-cli": "^5.0.0",
    "ajv-formats": "^3.0.1",
    "eslint-config-prettier": "^10.1.8",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "lefthook": "^2.1.9",
    "markdownlint-cli": "^0.48.0",
    "prettier": "^3.8.4",
    "remark": "^15.0.1",
    "remark-cli": "^12.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-lint": "^10.0.1",
    "remark-lint-frontmatter-schema": "^3.15.4",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "unified": "^11.0.5",
    "vitepress": "^1.6.4",
    "vitepress-sidebar": "^1.36.1",
    "vitest": "^4.1.8"
  }
}
