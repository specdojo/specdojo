{
  "name": "specdojo",
  "version": "0.1.0",
  "description": "SpecDojo CLI, schemas, and documentation for specification-driven execution workflows.",
  "license": "MIT",
  "author": "naoji3x",
  "private": false,
  "type": "module",
  "bin": {
    "specdojo": "dist/specdojo.js"
  },
  "files": [
    "dist",
    "docs/ja/specdojo",
    "docs/specdojo",
    "tools/docs/src",
    "tools/docs/tsconfig.json",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/specdojo/specdojo.git"
  },
  "homepage": "https://github.com/specdojo/specdojo#readme",
  "bugs": {
    "url": "https://github.com/specdojo/specdojo/issues"
  },
  "keywords": [
    "specdojo",
    "cli",
    "specification",
    "project-management",
    "workflow"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepare": "lefthook install",
    "pre-commit": "lefthook run pre-commit",
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.json && node -e \"require('node:fs').chmodSync('dist/specdojo.js', 0o755)\"",
    "dev": "tsx src/specdojo.ts",
    "start": "node dist/specdojo.js",
    "prepack": "npm run build",
    "specdojo:build": "npm run build",
    "lint:md": "markdownlint '**/*.md'",
    "lint:md:fix": "markdownlint --fix '**/*.md'",
    "docs:dev": "vitepress dev docs --host 0.0.0.0 --port 5173",
    "docs:build:mermaid": "tsx tools/docs/src/gen-mermaid-svg.ts",
    "docs:rebuild:mermaid": "rm -f docs/public/mermaid/*.svg && npm run docs:build:mermaid",
    "docs:build": "vitepress build docs",
    "lint:fm": "remark \"docs/**/*.{md,mdx}\" --quiet --frail",
    "validate:schema:bdd": "ajv --spec=draft2020 --strict=true -s docs/specdojo/schemas/v1/bdd.schema.yaml -d \"docs/**/bdd-*.yaml\"",
    "validate:schema:esil": "ajv --spec=draft2020 --strict=true -s docs/specdojo/schemas/v1/esil.schema.yaml -d \"docs/**/esil-*.yaml\"",
    "validate:schema:sch-milestones": "tsx tools/docs/src/validate-yaml-schema.ts --schema docs/specdojo/schemas/v1/sch-milestones.schema.yaml --data \"docs/ja/**/sch-milestones*.yaml\"",
    "validate:schema:sch-track": "tsx tools/docs/src/validate-yaml-schema.ts --schema docs/specdojo/schemas/v1/sch-track.schema.yaml --data \"docs/ja/**/sch-track-*.yaml\" --allow-empty",
    "validate:schema:sch-strategy": "tsx tools/docs/src/validate-yaml-schema.ts --schema docs/specdojo/schemas/v1/sch-strategy.schema.yaml --data \"docs/ja/**/sch-strategy-*.yaml\" --allow-empty",
    "validate:schema:file": "tsx tools/docs/src/validate-yaml-schema.ts",
    "validate:schema:pjr-index": "tsx tools/docs/src/validate-md-content.ts --schema docs/specdojo/schemas/v1/pjr-index.schema.yaml --data \"docs/ja/**/pjr-index.md\"",
    "validate:schema": "npm run validate:schema:bdd && npm run validate:schema:esil && npm run validate:schema:sch-milestones && npm run validate:schema:sch-track && npm run validate:schema:sch-strategy && npm run validate:schema:pjr-index",
    "validate:templates": "tsx tools/docs/src/validate-templates.ts",
    "check": "npm run lint:md && npm run lint:fm && npm run validate:schema && npm run validate:templates",
    "dc:ps": "docker ps --format \"table {{.Names}}\\t{{.Image}}\\t{{.Status}}\"",
    "dc:name": "bash -lc 'docker ps --format \"{{.Names}}\\t{{.Image}}\" | awk \"\\$2 ~ /^vsc-specdojo/ {print \\$1; exit}\"'",
    "dc:bash": "bash -lc 'name=$(docker ps --format \"{{.Names}}\\t{{.Image}}\" | awk \"\\$2 ~ /^vsc-specdojo/ {print \\$1; exit}\"); [ -n \"$name\" ] && docker exec -it -u node \"$name\" bash -lc \"cd /workspaces/specdojo && exec bash\" || echo \"matching container not found\"'"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.10.1",
    "ajv": "^8.18.0",
    "ajv-cli": "^5.0.0",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "lefthook": "^2.0.2",
    "markdownlint-cli": "^0.45.0",
    "prettier": "^3.6.2",
    "remark": "^15.0.1",
    "remark-cli": "^12.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-lint": "^10.0.1",
    "remark-lint-frontmatter-schema": "^3.15.4",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "unified": "^11.0.5",
    "vitepress": "^1.6.4",
    "vitepress-sidebar": "^1.33.0",
    "ajv-formats": "^2.1.1"
  }
}
