# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/dist

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
**/.tsbuild/
next-env.d.ts

# vs code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/schemas
!.vscode/markdown-preview.css

# env / secrets files
# because this project is public and template, don't include .env.* files
.env
.env.development
.env.production
.env.test
.env.staging
secrets/
config/credentials.json
*.key

# vitepress build output
/.vitepress/dist
/.vitepress/cache
/.vitepress/.temp
/public/mermaid
/local

# claude
.claude/settings.local.json
.claude/worktrees/
CLAUDE.local.md

# Codex local
.codex/auth.json
.codex/sessions/

# Copilot local
.github/copilot/settings.local.json

# OpenCode local
.opencode/auth.json
.opencode/sessions/

# specdojo VSCode extension
tools/vscode-specdojo/node_modules/
tools/vscode-specdojo/out/

# specdojo doc-index は root/worktree で都度再生成される生成物。
# commit すると exec の merge で衝突するため tracking しない。
.specdojo/doc-index.json

# specdojo build の生成物（generated/ 配下）。
# catalog/register/exec build が出力する派生ファイルで、timestamp 等で内容が変わる。
# VitePress build 時（docs:build の前段 docs:generate）に再生成するため tracking しない。
# ただし空ディレクトリを保持するための .gitkeep は追跡対象に残す。
docs/**/generated/*
!docs/**/generated/.gitkeep
/*.log
/logs/*.log
